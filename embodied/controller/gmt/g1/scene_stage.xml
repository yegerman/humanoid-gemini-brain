<mujoco model="g1 gmt stage scene">
  <!-- g1.xml is a complete scene (ground, light, keyframe). Add stage marker + cameras. -->
  <include file="g1.xml"/>

  <visual>
    <global offwidth="1920" offheight="1080"/>
  </visual>

  <asset>
    <material name="stage_mat" rgba="0.85 0.2 0.2 0.55"/>
    <material name="prop_blue"   rgba="0.20 0.35 0.85 1"/>
    <material name="prop_green"  rgba="0.20 0.70 0.30 1"/>
    <material name="prop_yellow" rgba="0.92 0.78 0.15 1"/>
    <material name="prop_orange" rgba="0.95 0.45 0.10 1"/>
    <material name="prop_purple" rgba="0.55 0.25 0.70 1"/>
  </asset>

  <worldbody>
    <!-- Stage center marker at (2.5, 0): a thin red disk the camera + overlay can see. -->
    <geom name="stage_center" type="cylinder" pos="2.5 0 0.006" size="0.45 0.005"
          material="stage_mat" contype="0" conaffinity="0"/>

    <!-- Stage props (static obstacles). Placed off the straight 0,0 -> 2.5,0 path. -->
    <geom name="prop_crate"  type="box"      pos="1.5 1.9 0.25"  size="0.25 0.25 0.25" material="prop_blue"/>
    <geom name="prop_ball"   type="sphere"   pos="3.6 1.4 0.30"  size="0.30"           material="prop_green"/>
    <geom name="prop_pillar" type="cylinder" pos="1.0 -2.0 0.45" size="0.20 0.45"      material="prop_yellow"/>
    <geom name="prop_block"  type="box"      pos="4.2 -1.3 0.30" size="0.30 0.30 0.30" material="prop_orange"/>
    <geom name="prop_post"   type="cylinder" pos="4.4 1.0 0.35"  size="0.12 0.35"      material="prop_purple"/>
    <!-- A low step block beside the stage (toward future stair work). -->
    <geom name="prop_step"   type="box"      pos="2.5 2.3 0.08"  size="0.6 0.4 0.08"   material="prop_blue"/>
    <!-- Carryable box (free body): the "pick & carry" payload. Grabbed via the disabled
         weld below ("magnetic gripper" stand-in, toggled at runtime by GMTController.grab). -->
    <body name="carry_box" pos="1.6 0.6 0.075">
      <freejoint name="carry_box_free"/>
      <geom name="carry_box_geom" type="box" size="0.06 0.06 0.06" mass="0.4"
            rgba="0.10 0.75 0.80 1" friction="0.9 0.005 0.0001"/>
    </body>
    <!-- Two more liftable boxes: bigger + lighter = easier to grab. -->
    <body name="box_magenta" pos="0.9 -0.5 0.09">
      <freejoint name="box_magenta_free"/>
      <geom name="box_magenta_geom" type="box" size="0.075 0.075 0.075" mass="0.25"
            rgba="0.90 0.15 0.65 1" friction="0.9 0.005 0.0001"/>
    </body>
    <body name="box_cyan2" pos="2.1 -0.9 0.09">
      <freejoint name="box_cyan2_free"/>
      <geom name="box_cyan2_geom" type="box" size="0.075 0.075 0.075" mass="0.25"
            rgba="0.15 0.85 0.90 1" friction="0.9 0.005 0.0001"/>
    </body>

    <!-- Third-person chase camera that follows the robot. -->
    <camera name="chase" pos="-2.2 -2.6 1.7" xyaxes="0.76 -0.65 0 0.28 0.33 0.9" mode="trackcom"/>
    <!-- Wide overview for the planner to see robot + stage. -->
    <camera name="overview" pos="1.2 -4.2 2.4" xyaxes="0.96 0.27 0 -0.13 0.46 0.88" mode="fixed"/>
  </worldbody>

  <equality>
    <!-- "Magnetic gripper": disabled welds between the right hand and each liftable box.
         GMTController.grab(True) enables the weld of the box NEAREST the hand. -->
    <weld name="grab" body1="right_rubber_hand" body2="carry_box" active="false"/>
    <weld name="grab_magenta" body1="right_rubber_hand" body2="box_magenta" active="false"/>
    <weld name="grab_cyan2" body1="right_rubber_hand" body2="box_cyan2" active="false"/>
  </equality>
</mujoco>
